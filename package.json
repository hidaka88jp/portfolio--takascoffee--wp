{
	"name": "takascoffee-theme",
	"private": true,
	"scripts": {
		"dev": "sass --watch src/scss:assets/css",
		"build": "sass src/scss:assets/css --style=compressed",
		"format": "prettier --write .",
		"lint:css": "stylelint \"src/scss/**/*.scss\"",
		"prepare": "husky",
    "lint-staged": "lint-staged"
	},
	"lint-staged": {
		"*.{js,scss,css}": [
			"prettier --write"
		],
		"*.scss": [
			"stylelint --fix"
		]
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"sass": "^1.97.3",
		"stylelint": "^17.3.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.0.0"
	}
}
